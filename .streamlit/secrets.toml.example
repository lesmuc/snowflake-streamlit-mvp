# Streamlit Cloud deployment — copy to secrets.toml and fill in values
# Do NOT commit secrets.toml to version control

[snowflake]
account = "your_account_identifier"
user = "your_username"
password = "your_password"
role = "SNOWFLAKE_LEARNING_ROLE"
warehouse = "SNOWFLAKE_LEARNING_WH"
database = "SNOWFLAKE_LEARNING_DB"
schema = "YOUR_USERNAME_LOAD_SAMPLE_DATA_FROM_S3"
